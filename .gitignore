.env

# Atlas repo clone (reproducible via scripts/core/setup.sh)
.atlas-repo/

# Generated index (rebuilt on refresh)
data/

# Python virtual environment
.venv/

# Ephemeral working files (PR bodies, diffs)
tmp/

# Session-specific plan files
.claude/plans/

# Per-user Claude Code overrides (permissions, env, etc.)
.claude/settings.local.json

# Claude Code debug logs
.claude/debug/

# Internal plans and notes
plans/

# Drafts of Messari intel summaries
intel-drafts/

# Per-user Claude Code slash commands
.claude/commands/

# Per-user session timestamp
.last-session

# Python bytecode
__pycache__/
*.pyc
*.pyo

# OS files
.DS_Store
