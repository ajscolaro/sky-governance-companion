.env

# Atlas repo clone (reproducible via scripts/core/setup.sh)
.atlas-repo/

# Generated index (rebuilt on refresh)
data/

# Python virtual environment
.venv/

# Ephemeral working files (PR bodies, diffs)
tmp/

# Session-specific plan files
.claude/plans/

# Internal plans and notes
plans/

# Per-user session timestamp
.last-session

# OS files
.DS_Store
