{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && if [ -d .atlas-repo/.git ]; then bash scripts/core/atlas-sync.sh 2>&1; else bash scripts/core/first-run-welcome.sh 2>&1; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/core/check-write-path.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Skill(atlas-navigate)",
      "Skill(atlas-analyze)",
      "Skill(history-search)",
      "Skill(forum-search)",
      "Skill(governance-data)",
      "Skill(messari-market-data)"
    ],
    "deny": [
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(rm -rf /*)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": ["."],
      "denyWrite": [".atlas-repo"],
      "denyRead": ["~/.ssh", "~/.gnupg", "~/.aws"]
    },
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "forum.skyeco.com",
        "vote.sky.money",
        "api.messari.io"
      ],
      "enableWeakerNetworkIsolation": true
    }
  }
}
